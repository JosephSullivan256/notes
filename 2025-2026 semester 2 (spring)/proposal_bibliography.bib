 @article{Arcara_Bertram_2009, title={{Reider}’s Theorem and {Thaddeus} Pairs Revisited}, url={http://arxiv.org/abs/0904.3500}, DOI={10.48550/arXiv.0904.3500}, abstractNote={Bridgeland stability conditions allow for a new generalization of Thaddeus pairs to surfaces and a new interpretation of Reider’s theorem as a consequence of “Schur’s lemma” for stable objects (Hom(E,F) = 0 if E,F are stable objects and the slope of E exceeds the slope of F). One improvement of Reider’s theorem results (Proposition 3.8/Corollary 3.9), and wall-crossings for the new Thaddeus pairs are discussed. This paper was submitted to the CMI conference proceedings celebrating the 65th birthday of Peter Newstead.}, note={arXiv:0904.3500 [math]}, number={arXiv:0904.3500}, author={Arcara, Daniele and Bertram, Aaron}, year={2009}, month=apr, language={en} }
 @article{Arcara_Bertram_Coskun_Huizenga_2012, title={The Minimal Model Program for the {Hilbert} Scheme of Points on $\mathbb{P}^2$ and Bridgeland Stability}, url={http://arxiv.org/abs/1203.0316}, DOI={10.48550/arXiv.1203.0316}, abstractNote={In this paper, we study the birational geometry of the Hilbert scheme P2[n] of n-points on P2. We discuss the stable base locus decomposition of the eﬀective cone and the corresponding birational models. We give modular interpretations to the models in terms of moduli spaces of Bridgeland semi-stable objects. We construct these moduli spaces as moduli spaces of quiver representations using G.I.T. and thus show that they are projective. There is a precise correspondence between wall-crossings in the Bridgeland stability manifold and wall-crossings between Mori cones. For n ≤ 9, we explicitly determine the walls in both interpretations and describe the corresponding ﬂips and divisorial contractions.}, note={arXiv:1203.0316 [math]}, number={arXiv:1203.0316}, publisher={arXiv}, author={Arcara, Daniele and Bertram, Aaron and Coskun, Izzet and Huizenga, Jack}, year={2012}, month=mar, language={en} }
 @article{Arcara_Bertram_Lieblich_2007, title={Bridgeland-Stable Moduli Spaces for K-Trivial Surfaces}, url={http://arxiv.org/abs/0708.2247}, DOI={10.48550/arXiv.0708.2247}, abstractNote={We give a natural family of Bridgeland stability conditions on the derived category of a smooth projective complex surface S and describe “wallcrossing behavior” for objects with the same invariants as OC (H) when H generates Pic(S) and C ∈ |H|. If, in addition, S is a K3 or Abelian surface, we use this description to construct a sequence of ﬁne moduli spaces of Bridgelandstable objects via Mukai ﬂops and generalized elementary modiﬁcations of the universal coherent sheaf. We also discover a natural generalization of Thaddeus’ stable pairs for curves embedded in the moduli spaces.}, note={arXiv:0708.2247 [math]}, number={arXiv:0708.2247}, publisher={arXiv}, author={Arcara, Daniele and Bertram, Aaron and Lieblich, Max}, year={2007}, month=aug, language={en} }
 @article{Bayer_2016, title={Wall-Crossing implies {Brill-Noether}. Applications of stability conditions on surfaces}, url={http://arxiv.org/abs/1604.08261}, DOI={10.48550/arXiv.1604.08261}, abstractNote={Over the last few years, wall-crossing for Bridgeland stability conditions has led to a large number of results in algebraic geometry, particular on birational geometry of moduli spaces. We illustrate some of the methods behind these result by reproving Lazarsfeld’s Brill-Noether theorem for curves on K3 surfaces via wall-crossing. We conclude with a survey of recent applications of stability conditions on surfaces. The intended reader is an algebraic geometer with a limited working knowledge of derived categories. This article is based on the author’s talk at the AMS Summer Institute on Algebraic Geometry in Utah, July 2015.}, note={arXiv:1604.08261 [math]}, number={arXiv:1604.08261}, author={Bayer, Arend}, year={2016}, month=oct, language={en} }
 @article{Bayer_Macrì_2014, title={Projectivity and birational geometry of Bridgeland moduli spaces}, volume={27}, ISSN={0894-0347, 1088-6834}, DOI={10.1090/S0894-0347-2014-00790-6}, abstractNote={We construct a family of nef divisor classes on every moduli space of stable complexes in the sense of Bridgeland. This divisor class varies naturally with the Bridgeland stability condition. For a generic stability condition on a K3 surface, we prove that this class is ample, thereby generalizing a result of Minamide, Yanagida, and Yoshioka. Our result also gives a systematic explanation of the relation between wall-crossing for Bridgeland-stability and the minimal model program for the moduli space.}, number={3}, journal={Journal of the American Mathematical Society}, author={Bayer, Arend and Macrì, Emanuele}, year={2014}, month=apr, pages={707–752}, language={en} }
 @article{Beilinson_1978, title={Coherent sheaves on Pn and problems of linear algebra}, volume={12}, rights={http://www.springer.com/tdm}, ISSN={0016-2663, 1573-8485}, DOI={10.1007/BF01681436}, number={3}, journal={Functional Analysis and Its Applications}, author={Beilinson, A. A.}, year={1978}, month=july, pages={214–216}, language={en} }
 @article{Beilinson_Ginzburg_Soergel_1996, title={Koszul Duality Patterns in Representation Theory}, volume={9}, ISSN={0894-0347}, abstractNote={The aim of this paper is to work out a concrete example as well as to provide the general pattern of applications of Koszul duality to representation theory. The paper consists of three parts relatively independent of each other. The first part gives a reasonably selfcontained introduction to Koszul rings and Koszul duality. Koszul rings are certain Z-graded rings with particularly nice homological properties which involve a kind of duality. Thus, to a Koszul ring one associates naturally the dual Koszul ring. The second part is devoted to an application to representation theory of semisimple Lie algebras. We show that the block of the Bernstein-Gelfand-Gelfand category O that corresponds to any fixed central character is governed by the Koszul ring. Moreover, the dual of that ring governs a certain subcategory of the category O again. This generalizes the selfduality theorem conjectured by Beilinson and Ginsburg in 1986 and proved by Soergel in 1990. In the third part we study certain categories of mixed perverse sheaves on a variety stratified by affine linear spaces. We provide a general criterion for such a category to be governed by a Koszul ring. In the flag variety case this reduces to the setup of part two. In the more general case of affine flag manifolds and affine Grassmannians the criterion should yield interesting results about representations of quantum groups and affine Lie algebras.}, number={2}, journal={Journal of the American Mathematical Society}, publisher={American Mathematical Society}, author={Beilinson, Alexander and Ginzburg, Victor and Soergel, Wolfgang}, year={1996}, pages={473–527} }
 @article{Belmans_Bose_Frei_Gould_Hotchkiss_Lamarche_Petok_Avila_Shah, title={On decompositions for Fano schemes of intersections of two quadrics}, abstractNote={We propose conjectural semiorthogonal decompositions for Fano schemes of linear subspaces on intersections of two quadrics, in terms of symmetric powers of the associated hyperelliptic (resp. stacky) curve. When the intersection is odd-dimensional, we moreover conjecture an identity in the Grothendieck ring of varieties and other motivic contexts. The evidence for these conjectures is given by upgrading recent results of Chen–Vilonen–Xue, to obtain formulae for the Hodge numbers of these Fano schemes. This allows us to numerically verify the conjecture in the hyperelliptic case, and establish a combinatorial identity as evidence for the stacky case.}, author={Belmans, Pieter and Bose, Jishnu and Frei, Sarah and Gould, Benjamin and Hotchkiss, James and Lamarche, Alicia and Petok, Jack and Avila, Cristian Rodriguez and Shah, Saket}, language={en} }
 @article{Belmans_Brecan_Franzen_Petrella_Reineke_2025, title={Rigidity and Schofield’s partial tilting conjecture for quiver moduli}, volume={12}, rights={https://creativecommons.org/licenses/by/4.0/}, ISSN={2429-7100, 2270-518X}, DOI={10.5802/jep.312}, abstractNote={We explain how Teleman quantization can be applied to moduli spaces of quiver representations, in order to compute the higher cohomology of the endomorphism bundle of the universal bundle. We use this to prove Schofield’s partial tilting conjecture in many interesting cases, and to show that moduli spaces of quiver representations are often (infinitesimally) rigid as varieties.}, journal={Journal de l’École polytechnique — Mathématiques}, author={Belmans, Pieter and Brecan, Ana-Maria and Franzen, Hans and Petrella, Gianni and Reineke, Markus}, year={2025}, month=sept, pages={1345–1379}, language={en} }
 @article{Bridgeland_King_Reid_2000, title={Mukai implies McKay: the McKay correspondence as an equivalence of derived categories}, url={http://arxiv.org/abs/math/9908027}, DOI={10.48550/arXiv.math/9908027}, abstractNote={Let G be a ﬁnite group of automorphisms of a nonsingular complex threefold M such that the canonical bundle ωM is locally trivial as a G-sheaf. We prove that the Hilbert scheme Y = G-Hilb M parametrising G-clusters in M is a crepant resolution of X = M/G and that there is a derived equivalence (Fourier–Mukai transform) between coherent sheaves on Y and coherent G-sheaves on M . This identiﬁes the K theory of Y with the equivariant K theory of M , and thus generalises the classical McKay correspondence. Some higher dimensional extensions are possible.}, note={arXiv:math/9908027}, number={arXiv:math/9908027}, publisher={arXiv}, author={Bridgeland, Tom and King, Alastair and Reid, Miles}, year={2000}, month=may, language={en} }
 @article{Craw, title={Explicit Methods for Derived Categories of Sheaves}, abstractNote={These notes aim to complement the lecture notes of C˘ald˘araru by providing an introduction to explicit methods in the study of derived categories in algebraic geometry. The bounded derived category of coherent sheaves on certain very simple algebraic varieties is equivalent to the bounded derived category of ﬁnitely generated modules over an algebra. We provide an introduction to this circle of ideas with a focus on explicit examples.}, author={Craw, Alastair}, language={en} }
 @article{Desale_Ramanan_1976, title={Classification of vector bundles of rank 2 on hyperelliptic curves}, volume={38}, rights={http://www.springer.com/tdm}, ISSN={0020-9910, 1432-1297}, DOI={10.1007/BF01408570}, number={2}, journal={Inventiones Mathematicae}, author={Desale, U. V. and Ramanan, S.}, year={1976}, month=june, pages={161–185}, language={en} }
 @article{Ein_Lazarsfeld, title={Lectures on the Syzygies and Geometry of Algebraic Varieties}, author={Ein, Lawrence and Lazarsfeld, Robert}, language={en} }
 @article{Hoskins_2018, title={Parallels between Moduli of Quiver Representations and Vector Bundles over Curves}, ISSN={18150659}, url={https://sigma-journal.com/2018/127/}, DOI={10.3842/SIGMA.2018.127}, abstractNote={This is a review article exploring similarities between moduli of quiver representations and moduli of vector bundles over a smooth projective curve. After describing the basic properties of these moduli problems and constructions of their moduli spaces via geometric invariant theory and symplectic reduction, we introduce their hyperk¨ahler analogues: moduli spaces of representations of a doubled quiver satisfying certain relations imposed by a moment map and moduli spaces of Higgs bundles. Finally, we survey a surprising link between the counts of absolutely indecomposable objects over ﬁnite ﬁelds and the Betti cohomology of these (complex) hyperk¨ahler moduli spaces due to work of Crawley-Boevey and Van den Bergh and Hausel, Letellier and Rodriguez-Villegas in the quiver setting, and work of Schiﬀmann in the bundle setting.}, journal={Symmetry, Integrability and Geometry: Methods and Applications}, author={Hoskins, Victoria}, year={2018}, month=dec, language={en} }
 @article{Kapranov_1988, title={On the derived categories of coherent sheaves on some homogeneous spaces}, volume={92}, rights={http://www.springer.com/tdm}, ISSN={0020-9910, 1432-1297}, DOI={10.1007/BF01393744}, number={3}, journal={Inventiones Mathematicae}, author={Kapranov, M. M.}, year={1988}, month=oct, pages={479–508}, language={en} }
 @inbook{Keller_2007, edition={1}, title={Derived categories and tilting}, rights={https://www.cambridge.org/core/terms}, ISBN={978-0-521-68045-5}, url={https://www.cambridge.org/core/product/identifier/CBO9780511735134A024/type/book_part}, DOI={10.1017/CBO9780511735134.005}, abstractNote={We review the basic deﬁnitions of derived categories and derived functors. We illustrate them on simple but non trivial examples. Then we explain Happel’s theorem which states that each tilting triple yields an equivalence between derived categories. We establish its link with Rickard’s theorem which characterizes derived equivalent algebras. We then examine invariants under derived equivalences. Using t-structures we compare two abelian categories having equivalent derived categories. Finally, we brieﬂy sketch a generalization of the tilting setup to diﬀerential graded algebras.}, booktitle={Handbook of Tilting Theory}, publisher={Cambridge University Press}, author={Keller, Bernhard}, editor={Angeleri Hügel, Lidia and Happel, Dieter and Krause, Henning}, year={2007}, month=jan, pages={49–104}, language={en} }
 @article{King_1994, title={Moduli of representations of finite dimensional algebras}, volume={45}, ISSN={0033-5606, 1464-3847}, DOI={10.1093/qmath/45.4.515}, number={4}, journal={The Quarterly Journal of Mathematics}, author={King, A. D.}, year={1994}, pages={515–530}, language={en} }
 @misc{King, title={Tilting Bundles on Some Rational Surfaces}, url={https://people.bath.ac.uk/masadk/papers/tilt.pdf}, note={unpublished manuscript}, author={King, Alastair} }
 @article{Kuznetsov_2005, title={Derived Categories of Quadric Fibrations and Intersections of Quadrics}, url={http://arxiv.org/abs/math/0510670}, DOI={10.48550/arXiv.math/0510670}, abstractNote={We construct a semiorthogonal decomposition of the derived category of coherent sheaves on a quadric ﬁbration consisting of several copies of the derived category of the base of the ﬁbration and the derived category of coherent sheaves of modules over the sheaf of even parts of the Cliﬀord algebras on the base corresponding to this quadric ﬁbration generalizing the Kapranov’s description of the derived category of a single quadric. As an application we verify that the noncommutative algebraic variety (P(S2W ∗), B0), where B0 is the universal sheaf of even parts of Cliﬀord algebras, is Homologically Projectively Dual to the projective space P(W ) in the double Veronese embedding P(W ) → P(S2W ). Using the properties of the Homological Projective Duality we obtain a description of the derived category of coherent sheaves on a complete intersection of any number of quadrics.}, note={arXiv:math/0510670}, number={arXiv:math/0510670}, publisher={arXiv}, author={Kuznetsov, Alexander}, year={2005}, month=oct, language={en} }
 @article{Kuznetsov_2015, title={Semiorthogonal decompositions in algebraic geometry}, url={http://arxiv.org/abs/1404.3143}, DOI={10.48550/arXiv.1404.3143}, abstractNote={In this review we discuss what is known about semiorthogonal decompositions of derived categories of algebraic varieties. We review existing constructions, especially the homological projective duality approach, and discuss some related issues such as categorical resolutions of singularities.}, note={arXiv:1404.3143 [math]}, number={arXiv:1404.3143}, publisher={arXiv}, author={Kuznetsov, Alexander}, year={2015}, month=jan, language={en} }
 @article{Orlov_1993, title={PROJECTIVE BUNDLES, MONOIDAL TRANSFORMATIONS, AND DERIVED CATEGORIES OF COHERENT SHEAVES}, volume={41}, ISSN={1064-5632}, DOI={10.1070/IM1993v041n01ABEH002182}, abstractNote={This paper studies derived categories of coherent sheaves onvarieties that are obtained by projectivization of vector bundles andby monoidal transformations. Conditions for the existence of complete exceptional sets in such categories are derived; they give new examples of varieties on which exceptional sets exist.}, number={1}, journal={Russian Academy of Sciences. Izvestiya Mathematics}, author={Orlov, D O}, year={1993}, month=feb, pages={133–141}, language={en} }
 @article{Petrella_2025, title={Partial semiorthogonal decompositions for quiver moduli}, volume={131}, ISSN={07477171}, DOI={10.1016/j.jsc.2025.102448}, abstractNote={We embed several copies of the derived category of a quiver and certain line bundles in the derived category of an associated moduli space of representations, giving the start of a semiorthogonal decomposition. This mirrors the semiorthogonal decompositions of moduli of vector bundles on curves. Our results are obtained with QuiverTools, an open-source package of tools for quiver representations, their moduli spaces and their geometrical properties.}, note={arXiv:2411.15125 [math]}, journal={Journal of Symbolic Computation}, author={Petrella, Gianni}, year={2025}, month=nov, pages={102448} }
