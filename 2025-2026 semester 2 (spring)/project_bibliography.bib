 @article{Thaddeus_1992, title={Stable pairs, linear systems and the Verlinde formula}, url={http://arxiv.org/abs/alg-geom/9210007}, DOI={10.48550/arXiv.alg-geom/9210007}, abstractNote={We study the moduli problem of pairs consisting of a rank 2 vector bundle and a nonzero section over a fixed smooth curve. The stability condition involves a parameter; as it varies, we show that the moduli space undergoes a sequence of flips in the sense of Mori. As applications, we prove several results about moduli spaces of rank 2 bundles, including the Harder-Narasimhan formula and the SU(2) Verlinde formula. Indeed, we prove a general result on the space of sections of powers of the ideal sheaf of a curve in projective space, which includes the Verlinde formula.}, note={arXiv:alg-geom/9210007}, number={arXiv:alg-geom/9210007}, author={Thaddeus, Michael}, year={1992}, month=oct, language={en} }
