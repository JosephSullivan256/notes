 @article{Beckmann_Belmans_2022, title={Homological projective duality for the Segre cubic}, url={http://arxiv.org/abs/2202.08601}, DOI={10.48550/arXiv.2202.08601}, abstractNote={The Segre cubic and Castelnuovo–Richmond quartic are two projectively dual hypersurfaces in P4, with a long and rich history starting in the 19th century. We will explain how Kuznetsov’s theory of homological projective duality lifts this projective duality to a relationship between the derived category of a small resolution of the Segre cubic and a small resolution of the Coble fourfold, the double cover of P4 rami ed along the Castelnuovo–Richmond quartic.}, note={arXiv:2202.08601 [math]}, number={arXiv:2202.08601}, publisher={arXiv}, author={Beckmann, Thorsten and Belmans, Pieter}, year={2022}, month=feb, language={en} }
 @article{Belmans_Bose_Frei_Gould_Hotchkiss_Lamarche_Petok_Avila_Shah, title={On decompositions for Fano schemes of intersections of two quadrics}, abstractNote={We propose conjectural semiorthogonal decompositions for Fano schemes of linear subspaces on intersections of two quadrics, in terms of symmetric powers of the associated hyperelliptic (resp. stacky) curve. When the intersection is odd-dimensional, we moreover conjecture an identity in the Grothendieck ring of varieties and other motivic contexts. The evidence for these conjectures is given by upgrading recent results of Chen–Vilonen–Xue, to obtain formulae for the Hodge numbers of these Fano schemes. This allows us to numerically verify the conjecture in the hyperelliptic case, and establish a combinatorial identity as evidence for the stacky case.}, author={Belmans, Pieter and Bose, Jishnu and Frei, Sarah and Gould, Benjamin and Hotchkiss, James and Lamarche, Alicia and Petok, Jack and Avila, Cristian Rodriguez and Shah, Saket}, language={en} }
 @article{Belmans_Krug_2024, title={Derived categories of (nested) Hilbert schemes}, volume={74}, ISSN={0026-2285}, url={http://arxiv.org/abs/1909.04321}, DOI={10.1307/mmj/20216092}, abstractNote={In this paper we provide several results regarding the structure of derived categories of (nested) Hilbert schemes of points. We show that the criteria of Krug–Sosna and Addington for the universal ideal sheaf functor to be fully faithful resp. a P-functor are sharp. Then we show how to embed multiple copies of the derived category of the surface using these fully faithful functors. We also give a semiorthogonal decomposition for the nested Hilbert scheme of points on a surface, and ﬁnally we give an elementary proof of a semiorthogonal decomposition due to Toda for the symmetric product of a curve.}, note={arXiv:1909.04321 [math]}, number={1}, journal={Michigan Mathematical Journal}, author={Belmans, Pieter and Krug, Andreas}, year={2024}, month=feb, language={en} }
 @article{Belmans_Raedschelders_2020, title={Derived categories of noncommutative quadrics and Hilbert squares}, volume={2020}, ISSN={1073-7928, 1687-0247}, DOI={10.1093/imrn/rny192}, abstractNote={A non-commutative deformation of a quadric surface is usually described by a three-dimensional cubic Artin–Schelter regular algebra. In this paper we show that for such an algebra its bounded derived category embeds into the bounded derived category of a commutative deformation of the Hilbert scheme of two points on the quadric. This is the second example in support of a conjecture by Orlov. Based on this example we formulate an inﬁnitesimal version of the conjecture, and provide some evidence in the case of smooth projective surfaces.}, note={arXiv:1605.02795 [math]}, number={19}, journal={International Mathematics Research Notices}, author={Belmans, Pieter and Raedschelders, Theo}, year={2020}, month=oct, pages={6042–6069}, language={en} }
 @phdthesis{Căldăraru_2000, title={Derived Categories of Twisted Sheaves on Calabi-Yau Manifolds}, url={https://people.math.wisc.edu/~caldararu/publications/ThesisSingleSpaced.pdf}, school={Cornell University}, author={Căldăraru, Andrei}, year={2000}, month=may }
 @article{Chen_Vilonen_Xue_2020, title={On the cohomology of Fano varieties and the Springer correspondence}, url={http://arxiv.org/abs/1602.03052}, DOI={10.48550/arXiv.1602.03052}, abstractNote={In this paper we compute the cohomology of the Fano varieties of k-planes in the smooth complete intersection of two quadrics in P2g+1, using Springer theory for symmetric spaces.}, note={arXiv:1602.03052 [math]}, number={arXiv:1602.03052}, publisher={arXiv}, author={Chen, Tsao-Hsien and Vilonen, Kari and Xue, Ting}, year={2020}, month=june, language={en} }
 @article{Chen_Vilonen_Xue_2021, title={Springer correspondence, hyperelliptic curves, and cohomology of Fano varieties}, url={http://arxiv.org/abs/1510.05986}, DOI={10.48550/arXiv.1510.05986}, abstractNote={In [CVX3], we have established a Springer theory for the symmetric pair (SL(N ), SO(N )). In this setting we obtain representations of (the Tits extension) of the braid group rather than just Weyl group representations. These representations arise from cohomology of families of certain (Hessenberg) varieties. In this paper we determine the Springer correspondence explicitly for IC sheaves supported on order 2 nilpotent orbits. In this process we encounter universal families of hyperelliptic curves. As an application we calculate the cohomolgy of Fano varieties of k-planes in the smooth intersection of two quadrics in an even dimensional projective space.}, note={arXiv:1510.05986 [math]}, number={arXiv:1510.05986}, publisher={arXiv}, author={Chen, Tsao-Hsien and Vilonen, Kari and Xue, Ting}, year={2021}, month=jan, language={en} }
 @article{Cheng_Perry_Zhao_2025, title={Derived categories of quartic double fivefolds}, url={http://arxiv.org/abs/2403.13463}, DOI={10.48550/arXiv.2403.13463}, abstractNote={We construct singular quartic double ﬁvefolds whose Kuznetsov component admits a crepant categorical resolution of singularities by a twisted Calabi–Yau threefold. We also construct rational specializations of these ﬁvefolds where such a resolution exists without a twist. This conﬁrms an instance of a higher-dimensional version of Kuznetsov’s rationality conjecture, and of a noncommutative version of Reid’s fantasy on the connectedness of the moduli of Calabi–Yau threefolds.}, note={arXiv:2403.13463 [math]}, number={arXiv:2403.13463}, publisher={arXiv}, author={Cheng, Raymond and Perry, Alexander and Zhao, Xiaolei}, year={2025}, month=apr, language={en} }
 @article{Desale_Ramanan_1976, title={Classification of vector bundles of rank 2 on hyperelliptic curves}, volume={38}, rights={http://www.springer.com/tdm}, ISSN={0020-9910, 1432-1297}, DOI={10.1007/BF01408570}, number={2}, journal={Inventiones Mathematicae}, author={Desale, U. V. and Ramanan, S.}, year={1976}, month=june, pages={161–185}, language={en} }
 @article{Fonarev_Kuznetsov_2018, title={Derived categories of curves as components of Fano manifolds}, volume={97}, ISSN={00246107}, DOI={10.1112/jlms.12094}, abstractNote={We prove that the derived category D(C) of a generic curve of genus greater than one embeds into the derived category D(M ) of the moduli space M of rank two stable bundles on C with ﬁxed determinant of odd degree.}, note={arXiv:1612.02241 [math]}, number={1}, journal={Journal of the London Mathematical Society}, author={Fonarev, Anton and Kuznetsov, Alexander}, year={2018}, month=feb, pages={24–46}, language={en} }
 @article{Franzen_Reineke_Sabatini_2021, title={Fano quiver moduli}, volume={64}, ISSN={0008-4395, 1496-4287}, DOI={10.4153/S0008439520001009}, abstractNote={We exhibit a large class of quiver moduli spaces which are Fano varieties, by studying line bundles on quiver moduli and their global sections in general, and work out several classes of examples, comprising moduli spaces of point conﬁgurations, Kronecker moduli, and toric quiver moduli.}, note={arXiv:2001.10556 [math]}, number={4}, journal={Canadian Mathematical Bulletin}, author={Franzen, Hans and Reineke, Markus and Sabatini, Silvia}, year={2021}, month=dec, pages={984–1000}, language={en} }
 @article{Jiang_Leung_2019, title={Blowing up linear categories, refinements, and homological projective duality with base locus}, url={http://arxiv.org/abs/1811.05132}, DOI={10.48550/arXiv.1811.05132}, abstractNote={In this paper, we ﬁrst introduce geometric operations for linear categories, and as a consequence generalize Orlov’s blow up formula [O04] to possibly singular local complete intersection centres. Second, we introduce reﬁned blowing up of linear category along base–locus, and show that this operation is dual to taking linear intersections. Finally, as an application we produce examples of Calabi–Yau manifolds which admits Calabi–Yau categories ﬁbrations over projective spaces.}, note={arXiv:1811.05132 [math]}, number={arXiv:1811.05132}, publisher={arXiv}, author={Jiang, Qingyuan and Leung, Naichung Conan}, year={2019}, month=sept, language={en} }
 @article{Jiang_Leung_2021, title={Derived category of projectivizations and flops}, url={http://arxiv.org/abs/1811.12525}, DOI={10.48550/arXiv.1811.12525}, abstractNote={In this paper, we prove a generalization of Orlov’s projectivization formula for the derived category $D^b_{rm coh} (mathbb{P}(mathscr{E}))$, where $mathscr{E}$ does not need to be a vector bundle; Instead, $mathscr{E}$ is a coherent sheaf which locally admits two-step resolutions. As a special case, this also gives Orlov’s generalized universal hyperplane section formula. As applications, (i) we obtain a blowup formula for blowup along codimension two Cohen-Macaulay subschemes, (ii) we obtain new “flop-flop=twist” results for a large class of flops obtained by crepant resolutions of degeneracy loci. As another consequence, this gives a perverse Schober on C. (iii) we give applications of the above results to symmetric powers of curves and $Θ$-flops, following Toda.}, note={arXiv:1811.12525 [math]}, number={arXiv:1811.12525}, publisher={arXiv}, author={Jiang, Qingyuan and Leung, Naichung Conan}, year={2021}, month=dec, language={en} }
 @article{Kuznetsov_2005, title={Derived Categories of Quadric Fibrations and Intersections of Quadrics}, url={http://arxiv.org/abs/math/0510670}, DOI={10.48550/arXiv.math/0510670}, abstractNote={We construct a semiorthogonal decomposition of the derived category of coherent sheaves on a quadric ﬁbration consisting of several copies of the derived category of the base of the ﬁbration and the derived category of coherent sheaves of modules over the sheaf of even parts of the Cliﬀord algebras on the base corresponding to this quadric ﬁbration generalizing the Kapranov’s description of the derived category of a single quadric. As an application we verify that the noncommutative algebraic variety (P(S2W ∗), B0), where B0 is the universal sheaf of even parts of Cliﬀord algebras, is Homologically Projectively Dual to the projective space P(W ) in the double Veronese embedding P(W ) → P(S2W ). Using the properties of the Homological Projective Duality we obtain a description of the derived category of coherent sheaves on a complete intersection of any number of quadrics.}, note={arXiv:math/0510670}, number={arXiv:math/0510670}, publisher={arXiv}, author={Kuznetsov, Alexander}, year={2005}, month=oct, language={en} }
 @article{Kuznetsov_2015, title={Semiorthogonal decompositions in algebraic geometry}, url={http://arxiv.org/abs/1404.3143}, DOI={10.48550/arXiv.1404.3143}, abstractNote={In this review we discuss what is known about semiorthogonal decompositions of derived categories of algebraic varieties. We review existing constructions, especially the homological projective duality approach, and discuss some related issues such as categorical resolutions of singularities.}, note={arXiv:1404.3143 [math]}, number={arXiv:1404.3143}, publisher={arXiv}, author={Kuznetsov, Alexander}, year={2015}, month=jan, language={en} }
 @article{Kuznetsov_Perry_2021, title={Homological projective duality for quadrics}, volume={30}, rights={https://www.ams.org/publications/copyright-and-permissions}, ISSN={1056-3911, 1534-7486}, DOI={10.1090/jag/767}, abstractNote={We show that over an algebraically closed ﬁeld of characteristic not equal to 2, homological projective duality for smooth quadric hypersurfaces and for double covers of projective spaces branched over smooth quadric hypersurfaces is a combination of two operations: one interchanges a quadric hypersurface with its classical projective dual and the other interchanges a quadric hypersurface with the double cover branched along it.}, number={3}, journal={Journal of Algebraic Geometry}, author={Kuznetsov, Alexander and Perry, Alexander}, year={2021}, month=jan, pages={457–476}, language={en} }
 @article{Narasimhan_2017, title={Derived categories of moduli spaces of vector bundles on curves}, volume={122}, ISSN={03930440}, DOI={10.1016/j.geomphys.2017.01.018}, abstractNote={Let X be a smooth projective curve of genus g ≥ 4 over C and M the moduli space of stable vector bundles of rank 2 and determinant isomorphic to a fixed line bundle of degree 1. We prove in this paper that Db (X ) is embedded (via ΦE ) in Db (M) as a full subcategory (if g ≥ 4).}, journal={Journal of Geometry and Physics}, author={Narasimhan, M.S.}, year={2017}, month=dec, pages={53–58}, language={en} }
 @article{Tevelev_2023, title={Braid and Phantom}, url={http://arxiv.org/abs/2304.01825}, DOI={10.48550/arXiv.2304.01825}, abstractNote={Let N be the moduli space of stable rank 2 vector bundles on a smooth projective curve of genus g ≥ 2 with fixed odd determinant. In [TT21], we previously found a semi-orthogonal decomposition of the bounded derived category of N into bounded derived categories of symmetric powers of the curve and, possibly, a phantom block. In this work, we employ the theory of weaving patterns to eliminate the possibility of a phantom, completing the proof of the decomposition conjectured by Narasimhan and, independently, by Belmans–Galkin–Mukhopadhyay.}, note={arXiv:2304.01825 [math]}, number={arXiv:2304.01825}, publisher={arXiv}, author={Tevelev, Jenia}, year={2023}, month=dec, language={en} }
 @article{Tevelev_Torres_2023, title={The BGMN conjecture via stable pairs}, url={http://arxiv.org/abs/2108.11951}, DOI={10.48550/arXiv.2108.11951}, abstractNote={Let C be a smooth projective curve of genus g ≥ 2 and let N be the moduli space of stable vector bundles on C of rank 2 and fixed determinant of odd degree. We construct a semi-orthogonal decomposition of Db(N ) conjectured by Narasimhan and by Belmans, Galkin and Mukhopadhyay. It has two blocks for each i-th symmetric power of C for i = 0, . . . , g − 2 and one block for the (g − 1)-st symmetric power. We conjecture that the subcategory generated by our blocks has a trivial semi-orthogonal complement, proving the full BGMN conjecture. Our proof is based on an analysis of wall-crossing between moduli spaces of stable pairs, combining classical vector bundles techniques with the method of windows.}, note={arXiv:2108.11951 [math]}, number={arXiv:2108.11951}, publisher={arXiv}, author={Tevelev, Jenia and Torres, Sebastián}, year={2023}, month=nov, language={en} }
